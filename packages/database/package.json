{
  "name": "@grounded/database",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:format": "DATABASE_URL=${DATABASE_URL:-postgresql://grounded:grounded@localhost:5432/grounded?schema=public} prisma format --schema prisma/schema.prisma",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://grounded:grounded@localhost:5432/grounded?schema=public} prisma generate --schema prisma/schema.prisma",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://grounded:grounded@localhost:5432/grounded?schema=public} prisma migrate dev --schema prisma/schema.prisma",
    "db:studio": "DATABASE_URL=${DATABASE_URL:-postgresql://grounded:grounded@localhost:5432/grounded?schema=public} prisma studio --schema prisma/schema.prisma",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://grounded:grounded@localhost:5432/grounded?schema=public} prisma validate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1"
  },
  "devDependencies": {
    "prisma": "^6.10.1"
  }
}
