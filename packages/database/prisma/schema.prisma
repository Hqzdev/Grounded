generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantRole {
  owner
  admin
  member
  viewer
}

enum ApiKeyStatus {
  active
  revoked
}

enum DocumentStatus {
  uploaded
  queued
  processing
  indexed
  failed
  deleted
}

enum DocumentSourceType {
  upload
  url
  notion
  text
}

enum IngestionJobStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum MessageRole {
  user
  assistant
  system
}

enum UsageEventType {
  document_embedded
  retrieval_executed
  question_answered
  generation_streamed
}

enum ProviderType {
  openai
  voyage
  local
  mock
}

enum AuthAuditEventType {
  user_registered
  email_verification_requested
  email_verified
  login_succeeded
  login_failed
  token_refreshed
  refresh_reuse_detected
  password_change_succeeded
  password_reset_requested
  password_reset_completed
  session_revoked
  logout
  logout_all
}

model Tenant {
  id            String          @id @default(cuid())
  slug          String          @unique
  name          String
  plan          String          @default("starter")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  apiKeys       ApiKey[]
  chatSessions  ChatSession[]
  citations     Citation[]
  chunks        DocumentChunk[]
  documents     Document[]
  ingestionJobs IngestionJob[]
  memberships   Membership[]
  messages      Message[]
  usageLedger   UsageLedger[]
}

model User {
  id                String                   @id @default(cuid())
  email             String                   @unique
  name              String
  passwordHash      String?
  avatarUrl         String?
  emailVerifiedAt   DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  apiKeys           ApiKey[]
  auditEvents       AuthAuditEvent[]
  chatSessions      ChatSession[]
  emailTokens       UserEmailVerification[]
  memberships       Membership[]
  messages          Message[]
  passwordTokens    PasswordResetToken[]
  refreshTokens     RefreshToken[]
  sessions          UserSession[]
  uploadedDocs      Document[]               @relation("DocumentUploader")
  usageLedger       UsageLedger[]
}

model UserSession {
  id           String         @id @default(cuid())
  userId       String
  tenantId     String?
  familyId     String
  ipAddress    String?
  userAgent    String?
  deviceLabel  String?
  createdAt    DateTime       @default(now())
  lastSeenAt   DateTime       @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  auditEvents  AuthAuditEvent[]
  refreshTokens RefreshToken[]
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([expiresAt])
}

model RefreshToken {
  id          String      @id @default(cuid())
  userId      String
  sessionId   String
  familyId    String
  tokenHash   String      @unique
  createdAt   DateTime    @default(now())
  expiresAt   DateTime
  usedAt      DateTime?
  revokedAt   DateTime?
  replacedById String?
  session     UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([sessionId])
  @@index([familyId])
  @@index([expiresAt])
}

model UserEmailVerification {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  email      String
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  usedAt     DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  usedAt     DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model AuthAuditEvent {
  id        String             @id @default(cuid())
  userId    String?
  sessionId String?
  eventType AuthAuditEventType
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime           @default(now())
  session   UserSession?       @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([eventType, createdAt])
}

model DevEmailOutbox {
  id        String   @id @default(cuid())
  recipient String
  subject   String
  token     String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([recipient, createdAt])
}

model Membership {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(member)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, role])
}

model ApiKey {
  id          String       @id @default(cuid())
  tenantId    String
  createdById String
  name        String
  keyHash     String       @unique
  status      ApiKeyStatus @default(active)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([createdById])
}

model Document {
  id             String             @id @default(cuid())
  tenantId       String
  uploadedById   String
  title          String
  filename       String
  contentType    String
  sourceType     DocumentSourceType @default(upload)
  status         DocumentStatus     @default(uploaded)
  currentVersion Int                @default(1)
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  chunks         DocumentChunk[]
  ingestionJobs  IngestionJob[]
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy     User               @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  versions       DocumentVersion[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([uploadedById])
}

model DocumentVersion {
  id            String          @id @default(cuid())
  documentId    String
  tenantId      String
  version       Int
  objectKey     String
  checksum      String
  byteSize      Int
  extractedText String?
  createdAt     DateTime        @default(now())
  chunks        DocumentChunk[]
  document      Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ingestionJobs IngestionJob[]

  @@unique([documentId, version])
  @@index([tenantId])
  @@index([documentId])
}

model DocumentChunk {
  id                String          @id @default(cuid())
  tenantId          String
  documentId        String
  documentVersionId String
  chunkIndex        Int
  content           String
  tokenCount        Int
  pageNumber        Int?
  sectionTitle      String?
  sourceStart       Int?
  sourceEnd         Int?
  qdrantPointId     String?         @unique
  createdAt         DateTime        @default(now())
  citations         Citation[]
  document          Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([documentVersionId, chunkIndex])
  @@index([tenantId, documentId])
  @@index([tenantId, qdrantPointId])
}

model IngestionJob {
  id                String             @id @default(cuid())
  tenantId          String
  documentId        String
  documentVersionId String
  status            IngestionJobStatus @default(queued)
  attempts          Int                @default(0)
  errorCode         String?
  errorMessage      String?
  queuedAt          DateTime           @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  document          Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion   DocumentVersion    @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([documentId])
  @@index([queuedAt])
}

model ChatSession {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([tenantId, updatedAt])
  @@index([userId, updatedAt])
}

model Message {
  id            String        @id @default(cuid())
  tenantId      String
  sessionId     String
  userId        String?
  role          MessageRole
  content       String
  inputTokens   Int?
  outputTokens  Int?
  estimatedCost Decimal?      @db.Decimal(12, 6)
  model         String?
  provider      ProviderType?
  createdAt     DateTime      @default(now())
  citations     Citation[]
  session       ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  usageLedger   UsageLedger[]

  @@index([tenantId, sessionId, createdAt])
  @@index([userId])
}

model Citation {
  id            String        @id @default(cuid())
  tenantId      String
  messageId     String
  documentId    String
  chunkId       String
  documentTitle String
  pageNumber    Int?
  snippet       String
  score         Float
  sourceStart   Int?
  sourceEnd     Int?
  createdAt     DateTime      @default(now())
  chunk         DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Restrict)
  message       Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, messageId])
  @@index([tenantId, documentId])
  @@index([chunkId])
}

model UsageLedger {
  id            String         @id @default(cuid())
  tenantId      String
  userId        String?
  messageId     String?
  eventType     UsageEventType
  provider      ProviderType
  model         String
  inputTokens   Int            @default(0)
  outputTokens  Int            @default(0)
  totalTokens   Int            @default(0)
  estimatedCost Decimal        @db.Decimal(12, 6)
  metadata      Json?
  createdAt     DateTime       @default(now())
  message       Message?       @relation(fields: [messageId], references: [id], onDelete: SetNull)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, eventType])
  @@index([userId, createdAt])
  @@index([messageId])
}
